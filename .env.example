# ── Supabase project ─────────────────────────────────────────────────────────
# Found at: Supabase Dashboard → Settings → API

# Project URL (used in both the Edge Function and the frontend JS)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service-role key — SERVER SIDE ONLY. Set as an Edge Function secret.
# Never expose this in frontend code or version control.
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<value>
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anon/public key — safe to embed in client-side JavaScript.
# Update the SUPABASE_ANON_KEY constant in website/js/site.js.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Create an account at resend.com, verify your sending domain, then copy the API key.
# Set as an Edge Function secret:
# supabase secrets set RESEND_API_KEY=<value>
RESEND_API_KEY=re_...

# The "From" address — must be a verified sender on your Resend account.
FROM_EMAIL=trust@yourcompany.com

# Company display name used in email templates.
COMPANY_NAME=YourCompany

# ── Frontend (website/js/site.js) ────────────────────────────────────────────
# Replace these two placeholders in website/js/site.js:
#   EDGE_FUNCTION_URL  →  ${SUPABASE_URL}/functions/v1/request-docs
#   SUPABASE_ANON_KEY  →  value from SUPABASE_ANON_KEY above

# ── Supabase Storage ─────────────────────────────────────────────────────────
# Create a private bucket named "audit-docs" in your Supabase project.
# Upload PDF files with these exact paths:
#
#   soc2.pdf          → SOC 2 Type II report
#   iso27001.pdf      → ISO 27001 SoA summary
#   cmmc.pdf          → CMMC assessment workbook
#   pentest.pdf       → Penetration test executive summary
#   dpa.pdf           → Data Processing Agreement
#   questionnaire.pdf → Security questionnaire (CAIQ/SIG/VSAQ)
#
# Bucket access: private (the Edge Function generates 7-day signed URLs)

# ── Deploy Edge Function ─────────────────────────────────────────────────────
# supabase functions deploy request-docs --no-verify-jwt
#
# Then set secrets:
# supabase secrets set \
#   SUPABASE_SERVICE_ROLE_KEY=... \
#   RESEND_API_KEY=... \
#   FROM_EMAIL=trust@yourcompany.com \
#   COMPANY_NAME=YourCompany

# ── Run DB migration ─────────────────────────────────────────────────────────
# supabase db push
# (or apply supabase/migrations/20260501000000_document_requests.sql manually
#  via the Supabase SQL editor)
