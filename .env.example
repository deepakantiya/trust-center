# ── Supabase project ─────────────────────────────────────────────────────────
# Found at: Supabase Dashboard → Settings → API Keys

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# ── Keys ──────────────────────────────────────────────────────────────────────
# Publishable key — safe to embed in client-side JS.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Service role key — SERVER SIDE ONLY (Edge Functions).
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<value>
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Vercel environment variables ──────────────────────────────────────────────
# Set these in Vercel Dashboard → Project → Settings → Environment Variables.

# Full URL of the request-documents edge function.
# This single function generates 7-day signed URLs for the requested PDFs.
EDGE_FUNCTION_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/request-documents

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Create a PRIVATE bucket named "audit-docs" in Supabase Dashboard → Storage.
# Upload PDF files with these exact paths (root of the bucket):
#
#   soc2.pdf          → SOC 2 Type II report
#   iso27001.pdf      → ISO 27001 SoA summary
#   cmmc.pdf          → CMMC assessment workbook
#   pentest.pdf       → Penetration test executive summary
#   dpa.pdf           → Data Processing Agreement
#   questionnaire.pdf → Security questionnaire (CAIQ/SIG/VSAQ)

# ── Deploy Edge Function ─────────────────────────────────────────────────────
# supabase functions deploy request-documents --no-verify-jwt
#
# Set secrets (Edge Function needs these at runtime):
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Run DB migrations ─────────────────────────────────────────────────────────
# supabase db push
#
# Migrations applied (in order):
#   20260501000000_document_requests.sql        — main requests table
#   20260501000001_document_requests_add_links.sql — adds links jsonb column
#   20260502000000_short_urls.sql               — short URL redirects (optional)
