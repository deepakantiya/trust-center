# ── Supabase project ─────────────────────────────────────────────────────────
# Found at: Supabase Dashboard → Settings → API Keys (JWT Signing Keys)

# Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# ── Keys (JWT Signing Keys — current standard) ───────────────────────────────
# Generate in: Dashboard → Settings → API Keys → "Create new key"

# Publishable key (sb_publishable_...) — safe to embed in client-side JS.
# Update the SUPABASE_PUBLISHABLE_KEY constant in website/js/site.js.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key (sb_secret_...) — SERVER SIDE ONLY. Set as an Edge Function secret.
# supabase secrets set SUPABASE_SECRET_KEY=<value>
SUPABASE_SECRET_KEY=sb_secret_...

# (Legacy fallbacks — only needed if your project hasn't migrated to JWT Signing Keys.)
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Supabase Storage ─────────────────────────────────────────────────────────
# Create a PRIVATE bucket named "audit-docs" in your Supabase project.
# Upload PDF files with these exact paths:
#
#   soc2.pdf          → SOC 2 Type II report
#   iso27001.pdf      → ISO 27001 SoA summary
#   cmmc.pdf          → CMMC assessment workbook
#   pentest.pdf       → Penetration test executive summary
#   dpa.pdf           → Data Processing Agreement
#   questionnaire.pdf → Security questionnaire (CAIQ/SIG/VSAQ)
#
# Bucket must be PRIVATE — the Edge Function generates 7-day unique signed URLs
# per submission and returns them directly to the browser. No email needed.

# ── Deploy Edge Function ─────────────────────────────────────────────────────
# supabase functions deploy Deno-Edge-Function --no-verify-jwt
#
# Set secrets:
# supabase secrets set SUPABASE_SECRET_KEY=sb_secret_...
#
# Disable JWT verification in Console → Edge Functions → Deno-Edge-Function
# → Configuration → toggle "Enforce JWT Verification" OFF

# ── Run DB migrations ────────────────────────────────────────────────────────
# Apply both migrations via Supabase SQL Editor or:
# supabase db push
#
#   20260501000000_document_requests.sql  — creates the table
#   20260501000001_document_requests_add_links.sql  — adds links jsonb column
